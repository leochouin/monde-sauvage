# ─────────────────────────────────────────────────────────────────────────────
# monde-sauvage Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe (Frontend — publishable key, safe to expose) ──
# Get from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (Supabase Edge Functions — set via `supabase secrets set`) ──
# These are NOT needed in .env — they go in Supabase secrets
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FRONTEND_URL=http://localhost:5173

# ── Mapbox ──
# Get from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your-mapbox-token
